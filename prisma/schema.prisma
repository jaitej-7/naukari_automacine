generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id             String   @id @default(cuid())
  serialNumber   String   @unique
  status         String   @default("Not Applied")
  appliedBy      String?
  appliedAt      String?
  resumeStatus   String   @default("Needs Resume")
  resumeFile     String?
  matchDecision  String   @default("Review")
  relevanceScore Int      @default(0)
  title          String
  company        String
  location       String?
  experience     String?
  salary         String?
  url            String?
  resumeFolder   String?
  searchKeywords String?
  capturedAt     String
  lastSeenAt     String
  notes          String?
  jobKey         String   @unique
  description    String?
  posted         String?
}

model RunLog {
  id           String   @id @default(cuid())
  startedAt    String
  finishedAt   String?
  jobCount     Int      @default(0)
  trackerCount Int      @default(0)
  actions      String   // Stored as JSON string
  warnings     String   // Stored as JSON string
}

model Configuration {
  id                   Int     @id @default(1)
  resumePath           String
  uploadEveryRun       Boolean @default(true)
  refreshProfile       Boolean @default(true)
  headline             String?
  profileSummary       String?
  keySkills            String  // Stored as JSON string
  maxResultsPerSearch  Int     @default(25)
  minRelevanceScore    Int     @default(2)
  searches             String  // JSON string
  includeKeywords      String  // JSON string
  excludeKeywords      String  // JSON string
  directApply          Boolean @default(true)
  createResumeFolder   Boolean @default(true)
  defaultStatus        String  @default("Not Applied")
  qaMemory             String  // JSON string
  statuses             String  // JSON string
  headless             Boolean @default(true)
  slowMoMs             Int     @default(120)
  manualLoginTimeoutMs Int     @default(300000)
}
